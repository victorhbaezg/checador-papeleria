# Copia este archivo a ".env" (sin .example) y llena los valores con
# tus credenciales reales de Supabase.
#
# Estos valores los obtienes en: supabase.com -> tu proyecto -> Settings -> API
#
# IMPORTANTE: el archivo ".env" NUNCA debe subirse a GitHub
# (ya esta protegido por .gitignore).

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-clave-anon-publica-aqui
